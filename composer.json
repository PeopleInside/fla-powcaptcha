{
    "name": "peopleinside/fla-powcaptcha",
    "description": "Local Proof-of-Work CAPTCHA for Flarum – protect login, registration and password reset without any external service",
    "keywords": ["flarum", "captcha", "security", "pow", "proof-of-work", "bot-protection"],
    "homepage": "https://github.com/PeopleInside/fla-powcaptcha",
    "license": "Apache-2.0",
    "type": "flarum-extension",
    "require": {
        "php": ">=8.1",
        "flarum/core": "^1.0 || ^2.0"
    },
    "autoload": {
        "psr-4": {
            "PeopleInside\\PowCaptcha\\": "src/"
        }
    },
    "archive": {
        "exclude": [
            "js/src",
            "js/package.json",
            "js/package-lock.json",
            "js/tsconfig.json",
            "js/webpack.config.js",
            "js/admin.ts",
            "js/forum.ts",
            "js/dist/*.map",
            ".gitignore"
        ]
    },
    "extra": {
        "flarum-extension": {
            "title": "PoW CAPTCHA",
            "category": "feature",
            "icon": {
                "name": "fas fa-shield-alt",
                "backgroundColor": "#2563eb",
                "color": "#ffffff"
            }
        },
        "flarum-cli": {
            "modules": {
                "admin": true,
                "forum": true,
                "js": true,
                "css": true,
                "locale": true
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
